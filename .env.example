# ===========================================
# Update Server Configuration
# ===========================================
# Development update server (used when running npm start)
DEV_UPDATE_SERVER_URL=https://your-dev-server.com

# Production update server (bundled into the app at build time)
PROD_UPDATE_SERVER_URL=https://your-prod-server.com

# For testing the production update server, you can override the URL with the following line:
TEST_UPDATE_SERVER_URL=https://your-test-server.com/test

# ===========================================
# Release Configuration (for scripts/release-update.ts)
# ===========================================
# SSH remote alias (defined in ~/.ssh/config)
RELEASE_SSH_ALIAS=your-server-alias

# Remote root directory on the server
RELEASE_REMOTE_ROOT=/path/to/your/static/files/directory

# Remote root directory for testing (optional, can be used to test the release process without affecting the main release directory)
TEST_REMOTE_ROOT=/path/to/your/static/files/directory/test